# Environment variables for California Law Chatbot
# Copy this file to .env and fill in your actual API keys

# ── Chat History (Clerk + Vercel KV + Vercel Blob) ─────────────────────────
# Clerk auth (get from https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx   # Client-side key (exposed to browser, safe)
CLERK_SECRET_KEY=sk_test_xxx              # Server-side only — NEVER expose to client
# CLERK_JWT_KEY=                          # Optional: for JWT verification without network call
# CLERK_AUTHORIZED_PARTIES=https://your-domain.vercel.app

# Upstash Redis (create at upstash.com → New Database → name it cal-law-chat-redis)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Vercel Blob (created via: vercel blob create cal-law-chat-blob or Vercel dashboard)
BLOB_READ_WRITE_TOKEN=vercel_blob_xxx
# ───────────────────────────────────────────────────────────────────────────

# Required: AWS Bedrock configuration for all Anthropic runtime calls
# Use IAM user/role credentials or another AWS-supported credential source.
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-west-2
# Optional:
# AWS_SESSION_TOKEN=YOUR_AWS_SESSION_TOKEN
# BEDROCK_AWS_REGION=us-west-2
# BEDROCK_API_KEY=YOUR_BEDROCK_API_KEY
# AWS_PROFILE=your-aws-profile
# AWS_BEARER_TOKEN_BEDROCK=YOUR_BEDROCK_BEARER_TOKEN
#
# Optional model overrides:
# BEDROCK_PRIMARY_MODEL=us.anthropic.claude-sonnet-4-6
# BEDROCK_FALLBACK_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_VERIFIER_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_DRAFTER_MODEL=us.anthropic.claude-sonnet-4-6
# BEDROCK_RESEARCH_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_ANTHROPIC_CHAT_MODEL=us.anthropic.claude-sonnet-4-6
# BEDROCK_PRIMARY_TIMEOUT_MS=60000
# BEDROCK_FALLBACK_TIMEOUT_MS=45000
# BEDROCK_VERIFIER_TIMEOUT_MS=60000
# BEDROCK_VERIFIER_MAX_TOKENS=4096

# Required for existing CEB embeddings / vector search
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Optional: CourtListener API key for case law research
# Get a token at https://www.courtlistener.com/help/api/
COURTLISTENER_API_KEY=YOUR_COURTLISTENER_API_KEY

# Optional: External web search for Bedrock-backed speed mode
# Exa is preferred (same pattern as Benjamin); Serper is the fallback.
# EXA_API_KEY=YOUR_EXA_API_KEY
# SERPER_API_KEY=YOUR_SERPER_API_KEY

# Optional: Legislative research APIs (handlers ready, integration pending)
# OpenStates: https://openstates.org/api/
OPENSTATES_API_KEY=YOUR_OPENSTATES_API_KEY

# LegiScan: https://legiscan.com/legiscan (30k free queries/month)
LEGISCAN_API_KEY=YOUR_LEGISCAN_API_KEY
