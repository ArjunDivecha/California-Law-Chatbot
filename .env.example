# Environment variables for California Law Chatbot
# Copy this file to .env and fill in your actual API keys

# ── Chat History (Clerk + Vercel KV + Vercel Blob) ─────────────────────────
# Clerk auth (get from https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx   # Client-side key (exposed to browser, safe)
CLERK_SECRET_KEY=sk_test_xxx              # Server-side only — NEVER expose to client
# CLERK_JWT_KEY=                          # Optional: for JWT verification without network call
# CLERK_AUTHORIZED_PARTIES=https://your-domain.vercel.app

# Upstash Redis (create at upstash.com → New Database → name it cal-law-chat-redis)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Vercel Blob (created via: vercel blob create cal-law-chat-blob or Vercel dashboard)
BLOB_READ_WRITE_TOKEN=vercel_blob_xxx
# ───────────────────────────────────────────────────────────────────────────

# Required: Google GenAI / Vertex AI configuration for Gemini and verifier calls
# Vertex express mode with API key:
GOOGLE_GENAI_USE_VERTEXAI=true
VERTEX_API_KEY=YOUR_VERTEX_API_KEY
# Optional for standard Vertex projects:
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
# Fallback for direct Gemini API instead of Vertex:
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Required for existing CEB embeddings / vector search
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Optional: CourtListener API key for case law research
# Get a token at https://www.courtlistener.com/help/api/
COURTLISTENER_API_KEY=YOUR_COURTLISTENER_API_KEY

# Optional: Legislative research APIs (handlers ready, integration pending)
# OpenStates: https://openstates.org/api/
OPENSTATES_API_KEY=YOUR_OPENSTATES_API_KEY

# LegiScan: https://legiscan.com/legiscan (30k free queries/month)
LEGISCAN_API_KEY=YOUR_LEGISCAN_API_KEY
