{
  "name": "california-law-chatbot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node dev-server.js",
    "dev:full": "node dev-server.js & sleep 2 && vite",
    "build:shared": "esbuild api/_shared/*.ts api/_shared/sanitization/*.ts --outdir=api/_shared --outbase=api/_shared --format=esm --platform=node --target=node20 --log-level=warning",
    "typecheck:api": "tsc --noEmit --project tsconfig.api.json",
    "build": "npm run build:shared && npm run typecheck:api && vite build",
    "test:sanitization": "node --experimental-strip-types tests/sanitization.test.mjs",
    "test:goldset": "node --experimental-strip-types tests/goldSetValidation.test.mjs",
    "preview": "vite preview",
    "test:verification": "node test-verification-system.js",
    "test:openrouter": "node test-comprehensive.js",
    "test:confidentiality": "node --experimental-strip-types tests/confidentiality.test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.29.0",
    "@anthropic-ai/sdk": "^0.68.0",
    "@clerk/backend": "^3.2.8",
    "@clerk/clerk-react": "^5.61.4",
    "@google/genai": "^1.27.0",
    "@upstash/redis": "^1.37.0",
    "@upstash/vector": "^1.1.5",
    "@vercel/blob": "^2.3.3",
    "@vercel/kv": "^3.0.0",
    "docx": "^9.5.1",
    "dotenv": "^17.2.3",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.548.0",
    "openai": "^6.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.14.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.5.28",
    "@vitejs/plugin-react": "^5.0.0",
    "cors": "^2.8.6",
    "esbuild": "^0.25.0",
    "express": "^5.2.1",
    "fake-indexeddb": "^6.2.5",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "packageManager": "yarn@4.9.1+sha512.f95ce356460e05be48d66401c1ae64ef84d163dd689964962c6888a9810865e39097a5e9de748876c2e0bf89b232d583c33982773e9903ae7a76257270986538"
}
